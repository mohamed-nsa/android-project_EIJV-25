<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- ===== CONTENU PRINCIPAL ===== -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/background">

        <!-- Toolbar -->
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@color/background_toolbar"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <ImageButton
                android:id="@+id/btnMenu"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_menu"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/desc_menu"
                android:layout_gravity="start"
                app:tint="@color/text_primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/title_mes_evenements"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_gravity="center" />
        </androidx.appcompat.widget.Toolbar>

        <!-- Barre : Ajouter + Rechercher -->
        <LinearLayout
            android:id="@+id/barActions"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp"
            android:gravity="center_vertical"
            app:layout_constraintTop_toBottomOf="@id/toolbar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- Bouton Ajouter -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAddEvent"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="@string/btn_add_event"
                android:textSize="13sp"
                android:textColor="@color/white"
                app:icon="@android:drawable/ic_input_add"
                app:iconTint="@color/white"
                app:backgroundTint="@color/primary"
                app:cornerRadius="10dp"
                android:layout_marginEnd="8dp" />

            <!-- Champ de recherche -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilSearch"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1.3"
                app:boxStrokeColor="@color/primary"
                app:boxCornerRadiusTopStart="10dp"
                app:boxCornerRadiusTopEnd="10dp"
                app:boxCornerRadiusBottomStart="10dp"
                app:boxCornerRadiusBottomEnd="10dp"
                app:endIconMode="clear_text"
                app:hintTextColor="@color/text_secondary"
                android:hint="@string/hint_search_event">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etSearch"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:inputType="text"
                    android:textSize="13sp"
                    android:imeOptions="actionSearch" />
            </com.google.android.material.textfield.TextInputLayout>

        </LinearLayout>

        <!-- Message liste vide -->
        <TextView
            android:id="@+id/tvEmpty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/msg_no_events"
            android:textColor="@color/text_secondary"
            android:textSize="15sp"
            android:visibility="gone"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Liste des événements -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerEvenements"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:paddingHorizontal="12dp"
            android:paddingBottom="12dp"
            android:clipToPadding="false"
            app:layout_constraintTop_toBottomOf="@id/barActions"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- ===== MENU TIROIR ===== -->
    <include layout="@layout/nav_drawer_content"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="start" />

</androidx.drawerlayout.widget.DrawerLayout>